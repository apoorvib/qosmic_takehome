{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "store_profile.schema.json",
  "title": "Store profile",
  "description": "The specificity anchor. Every experiment's store_profile_ref must overlap with something here. commerce_model is load-bearing (retailer-routed vs direct decides KPI shape).",
  "type": "object",
  "required": ["store", "commerce_model", "families", "jobs_to_be_done", "proof_points"],
  "properties": {
    "store": { "type": "string" },
    "niche": { "type": "string" },
    "commerce_model": { "type": "string", "enum": ["retailer-routed", "direct", "hybrid"] },
    "families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "products": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "jobs_to_be_done": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "segments": { "type": "array", "items": { "type": "string" } },
    "proof_points": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "content_themes": { "type": "array", "items": { "type": "string" } },
    "brand_voice": { "type": "string" }
  },
  "additionalProperties": true
}
